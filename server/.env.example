# Copy this file to ".env" and adjust values.
MONGO_URI=mongodb://127.0.0.1:27017/wolf_erp
PORT=5000
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Optional SMTP (blank = emails are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Wolf ERP <no-reply@wolferp.in>
