!.env.example
!**/.env.example

# ---- Next.js build output ----
.next/
**/.next/
out/
build/
dist/

# ---- Server runtime artifacts ----
server/uploads/*
!server/uploads/.gitkeep

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Caches / coverage ----
.cache/
coverage/
.eslintcache
*.tsbuildinfo
next-env.d.ts

# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# ---- Misc temp ----
_smoke*.js
_e2e*.js
tmp/
*.tmp
