# ---- Dependencies ----
node_modules/
**/node_modules/
.pnp
.pnp.js

# ---- Secrets / local env (NEVER commit real secrets) ----
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
